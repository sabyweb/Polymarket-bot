# Polymarket Bot — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Wallet ────────────────────────────────────────────────────────────────────
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here
FUNDER=your_proxy_wallet_address_here

# ── CLOB API Credentials ─────────────────────────────────────────────────────
# Generate at: https://clob.polymarket.com
CLOB_API_KEY=your_api_key_here
CLOB_SECRET=your_api_secret_here
CLOB_PASS_PHRASE=your_passphrase_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Discord webhook for fill/crash notifications (leave blank to disable)
DISCORD_WEBHOOK_URL=

# Alchemy RPC key (only needed for check_wallet.py and revoke_allowances.py)
ALCHEMY_KEY=
